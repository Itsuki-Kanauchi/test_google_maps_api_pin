<div class="card w-96 bg-base-100 shadow-xl">
  <div class="card-body">
    <%= form_with model: post, local: true do |f| %>
      <div>
        <%= f.label :title %>
        <%= f.text_field :title, placeholder: "スポット名を入力してください", class: "input input-bordered w-full max-w-ws" %>
      </div>
      <div>
        <%= f.label :address %>
        <%= f.text_field :address, placeholder: "住所を入力してください", class: "input input-bordered w-full max-w-ws" %>
      </div>
    <% end %>
  </div>
</div>
