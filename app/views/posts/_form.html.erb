<div>
  <%= form_with model: post, local: true do |f| %>
    <div>
      <%= f.label :title %>
      <%= f.text_field :title, placeholder: "スポット名を入力してください" %>
    </div>
    <div>
      <%= f.label :address %>
      <%= f.text_field :address, placeholder: "住所を入力してください" %>
    </div>

    <%= f.submit %>
  <% end %>
</div>
